# PaddleOCR-VL Server
PPDOCLAYOUT_PADDLE_OCR_SERVER_URL=http://127.0.0.1:8000/v1
PPDOCLAYOUT_PADDLE_OCR_BACKEND=vllm-server

# PaddleOCR-VL Processing Options
PPDOCLAYOUT_PADDLE_OCR_FORMAT_BLOCK_CONTENT=true
PPDOCLAYOUT_PADDLE_OCR_USE_DOC_UNWARPING=false
PPDOCLAYOUT_PADDLE_OCR_USE_CHART_RECOGNITION=true
PPDOCLAYOUT_PADDLE_OCR_MERGE_LAYOUT_BLOCKS=true
PPDOCLAYOUT_PADDLE_OCR_LAYOUT_DETECTION_MODEL_NAME=PP-DocLayoutV3
PPDOCLAYOUT_PADDLE_OCR_USE_LAYOUT_DETECTION=true
PPDOCLAYOUT_PADDLE_USE_OCR_FOR_IMAGE_BLOCK=true

# Gemma/vLLM Server
PPDOCLAYOUT_VLLM_BASE_URL=http://127.0.0.1:8001/v1
PPDOCLAYOUT_VLLM_MAX_TOKENS=16384
PPDOCLAYOUT_VLLM_MODEL_NAME=Infomaniak-AI/vllm-translategemma-4b-it

# Batch sizes (parallel processing)
PPDOCLAYOUT_BATCH_SIZE_SMALL=16
PPDOCLAYOUT_BATCH_SIZE_MEDIUM=8
PPDOCLAYOUT_BATCH_SIZE_LARGE=4

# Paths
PPDOCLAYOUT_OUTPUT_DIR=output

# Export formats (comma-separated)
PPDOCLAYOUT_EXPORT_FORMATS_RAW=html,pdf
